<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Actualización Cliente</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <style>
      body { background-color: #f5f5f5; }
      .container { margin-top: 10px; }
      .card-panel { padding: 10px; }
      .input-field { margin-bottom: 2px; margin-top: 2px; }
      .loader-overlay {
        position: fixed; top: 0; left: 0; width: 100%; height: 100%;
        background-color: rgba(0, 0, 0, 0.7); display: none; flex-direction: column;
        justify-content: center; align-items: center; z-index: 9999; color: white; text-align: center;
      }
      .loader-spinner {
        border: 4px solid rgba(255, 255, 255, 0.3); border-top: 4px solid #fff;
        border-radius: 50%; width: 50px; height: 50px; animation: spin 1s linear infinite; margin-bottom: 10px;
      }
      .loader-text { font-size: 1.2em; font-weight: bold; }
      @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
    </style>
  </head>
  <body>
    
    <div id="loader" class="loader-overlay">
      <div class="loader-spinner"></div>
      <div id="loaderText" class="loader-text">Cargando datos cliente...</div>
    </div>
    
    <div class="container">
      <div class="row">
        <div class="col s12">
          <div class="card-panel grey lighten-5 z-depth-1">
            <h4 class="center-align">Actualización de Datos</h4>
            <div class="row">
              <form class="col s12" id="myForm">
                <div class="row">
                  <div class="input-field col s12">
                    <input id="RutEmpresa" type="text" class="validate" name="RutEmpresa" required readonly>
                    <label for="RutEmpresa" class="active">RUT Empresa (formato sin puntos y con guion)</label>
                  </div>
                </div>
                <div class="row">
                  <div class="input-field col s12">
                    <input id="RazonSocial" type="text" class="validate" name="RazonSocial">
                    <label for="RazonSocial" class="active">Razón Social</label>
                  </div>
                </div>
                <div class="row">
                  <div class="input-field col s12">
                    <select id="Industria" name="Industria">
                      <option value="" disabled selected>Seleccione una industria</option>
                      <option value="Construcción">Construcción</option>
                      <option value="Minería">Minería</option>
                      <option value="Agrícola">Agrícola</option>
                      <option value="Industrial">Industrial</option>
                      <option value="Comercio">Comercio</option>
                      <option value="Servicios">Servicios</option>
                      <option value="Otros">Otros</option>
                    </select>
                    <label>Industria</label>
                  </div>
                </div>
                <div class="row">
                  <div class="input-field col s12">
                    <input id="CalleNumero" type="text" class="validate" name="CalleNumero">
                    <label for="CalleNumero" class="active">Calle y Número</label>
                  </div>
                </div>
                <div class="row">
                  <div class="input-field col s12">
                    <input id="Comuna" type="text" class="validate" name="Comuna">
                    <label for="Comuna" class="active">Comuna</label>
                  </div>
                </div>
                <div class="row">
                  <div class="input-field col s12">
                    <select id="Region" name="Region">
                      <option value="" disabled selected>Seleccione una región</option>
                      <option value="Región de Arica y Parinacota">Arica y Parinacota</option>
                      <option value="Región de Tarapacá">Tarapacá</option>
                      <option value="Región de Antofagasta">Antofagasta</option>
                      <option value="Región de Atacama">Atacama</option>
                      <option value="Región de Coquimbo">Coquimbo</option>
                      <option value="Región de Valparaíso">Valparaíso</option>
                      <option value="Región del Libertador Gral. Bernardo O'Higgins">O'Higgins</option>
                      <option value="Región del Maule">Maule</option>
                      <option value="Región de Ñuble">Ñuble</option>
                      <option value="Región del Biobío">Biobío</option>
                      <option value="Región de La Araucanía">Araucanía</option>
                      <option value="Región de Los Ríos">Los Ríos</option>
                      <option value="Región de Los Lagos">Los Lagos</option>
                      <option value="Región de Aysén del Gral. Carlos Ibáñez del Campo">Aysén</option>
                      <option value="Región de Magallanes y de la Antártica Chilena">Magallanes</option>
                      <option value="Región Metropolitana de Santiago">Metropolitana de Santiago</option>
                    </select>
                    <label>Región</label>
                  </div>
                </div>
                <div class="row">
                  <h6 class="center-align">Contacto de Adquisiciones para Firma electrónica</h6>
                  <div class="input-field col s12">
                    <input id="NombreAdq" type="text" class="validate" name="NombreAdq">
                    <label for="NombreAdq" class="active">Nombre</label>
                  </div>
                  <div class="input-field col s12">
                    <input id="RutAdq" type="text" class="validate" name="RutAdq">
                    <label for="RutAdq" class="active">RUT del contacto</label>
                  </div>
                  <div class="input-field col s12">
                    <input id="EmailAdq" type="email" class="validate" name="EmailAdq">
                    <label for="EmailAdq" class="active">Email</label>
                  </div>
                  <div class="input-field col s12">
                    <input id="FonoAdq" type="tel" class="validate" name="FonoAdq">
                    <label for="FonoAdq" class="active">Fono</label>
                  </div>
                </div>
                <div class="row">
                  <h6 class="center-align">Contacto de Pago a Proveedores</h6>
                  <div class="input-field col s12">
                    <input id="NombrePago" type="text" class="validate" name="NombrePago">
                    <label for="NombrePago" class="active">Nombre completo contacto PP</label>
                  </div>
                  <div class="input-field col s12">
                    <input id="EmailPago" type="email" class="validate" name="EmailPago">
                    <label for="EmailPago" class="active">Correo electrónico PP</label>
                  </div>
                  <div class="input-field col s12">
                    <input id="FonoPago" type="tel" class="validate" name="FonoPago">
                    <label for="FonoPago" class="active">Teléfono móvil PP</label>
                  </div>
                </div>
                <div class="row">
                  <div class="input-field col s12">
                    <button class="btn waves-effect waves-light" type="submit" name="action">Actualizar en SAP
                      <i class="material-icons right">send</i>
                    </button>
                  </div>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>
    <script>
      // 👇 REEMPLAZA ESTA URL POR LA DE TU WEBHOOK DE UPDATE EN N8N 👇
      const WEBHOOK_UPDATE_BP = 'https://alogroup.app.n8n.cloud/webhook/sap/updateBP';

      const ADQ_FIELDS = ['NombreAdq', 'RutAdq', 'EmailAdq', 'FonoAdq'];
      const PAGO_FIELDS = ['NombrePago', 'EmailPago', 'FonoPago'];
      const ALL_CONTACT_FIELDS = ADQ_FIELDS.concat(PAGO_FIELDS);

      document.addEventListener('DOMContentLoaded', function() {
        M.FormSelect.init(document.querySelectorAll('select'));

        // Extraer datos de la sesión guardada en index.html
        const storedRut = sessionStorage.getItem('sapRut');
        const storedData = sessionStorage.getItem('sapClientData');

        if (!storedRut || !storedData) {
            // Protección: Si alguien entra directo a esta URL sin pasar por el login, lo devuelve al inicio
            window.location.href = 'index.html';
            return;
        }

        document.getElementById('RutEmpresa').value = storedRut;
        const parsedData = JSON.parse(storedData);
        fillForm(parsedData);

        ALL_CONTACT_FIELDS.forEach(fieldId => {
            const input = document.getElementById(fieldId);
            if (input) input.addEventListener('input', validarCampos);
        });
      });

      function fillForm(data) {
        // Gracias a N8N, los datos ya vienen limpios y estructurados!
        document.getElementById('RazonSocial').value = data.CardName || '';
        document.getElementById('Industria').value = data.Industria || '';
        
        if (data.Direccion) {
            document.getElementById('CalleNumero').value = data.Direccion.Calle || '';
            document.getElementById('Comuna').value = data.Direccion.Comuna || '';
            document.getElementById('Region').value = data.Direccion.Region || '';
        }
        
        if (data.Contactos && data.Contactos.Adquisiciones) {
            document.getElementById('NombreAdq').value = data.Contactos.Adquisiciones.Nombre || '';
            document.getElementById('RutAdq').value = data.Contactos.Adquisiciones.Rut || '';
            document.getElementById('EmailAdq').value = data.Contactos.Adquisiciones.Email || '';
            document.getElementById('FonoAdq').value = data.Contactos.Adquisiciones.Fono || '';
        }

        if (data.Contactos && data.Contactos.PagoProveedores) {
            document.getElementById('NombrePago').value = data.Contactos.PagoProveedores.Nombre || '';
            document.getElementById('EmailPago').value = data.Contactos.PagoProveedores.Email || '';
            document.getElementById('FonoPago').value = data.Contactos.PagoProveedores.Fono || '';
        }
        
        M.updateTextFields();
        M.FormSelect.init(document.querySelectorAll('select'));
        validarCampos(); 
      }

      function validarCampos() {
        ALL_CONTACT_FIELDS.forEach(fieldId => {
            const input = document.getElementById(fieldId);
            const value = input.value.trim();
            
            if (value === '') {
                input.classList.remove('valid'); input.classList.add('invalid'); return; 
            }
            
            let isFormatValid = true;
            if (fieldId === 'RutAdq' && !validaRut(value)) isFormatValid = false;
            if ((fieldId === 'EmailAdq' || fieldId === 'EmailPago') && !isValidEmail(value)) isFormatValid = false;
            if ((fieldId === 'FonoAdq' || fieldId === 'FonoPago') && !isValidPhone(value)) isFormatValid = false;

            if (!isFormatValid) {
                input.classList.remove('valid'); input.classList.add('invalid');
            } else {
                input.classList.remove('invalid'); input.classList.add('valid');
            }
        });
      }

      document.getElementById('myForm').addEventListener('submit', async function(event) {
        event.preventDefault();
        
        const form = event.target;
        const formData = new FormData(form);
        const dataObject = {};
        formData.forEach((value, key) => { dataObject[key] = value.trim(); });
        
        const storedData = JSON.parse(sessionStorage.getItem('sapClientData'));
        dataObject.CardCode = storedData.CardCode;
       
        
        let isValid = true;
        validarCampos(); 

        const errorMessages = {
            'NombreAdq': 'El nombre de Adquisiciones es obligatorio.',
            'RutAdq': 'El RUT de Adquisiciones es obligatorio o inválido.',
            'EmailAdq': 'El email de Adquisiciones es obligatorio o inválido.',
            'FonoAdq': 'El teléfono de Adquisiciones es obligatorio o inválido.',
            'NombrePago': 'El nombre de Pago a Proveedores es obligatorio.',
            'EmailPago': 'El email de Pago a Proveedores es obligatorio o inválido.',
            'FonoPago': 'El teléfono de Pago a Proveedores es obligatorio o inválido.'
        };
        
        ALL_CONTACT_FIELDS.forEach(fieldId => {
            const input = document.getElementById(fieldId);
            if (dataObject[fieldId] === '' || input.classList.contains('invalid')) {
                M.toast({html: `❌ ${errorMessages[fieldId] || 'Campo requerido o inválido.'}`, classes: 'red darken-1'});
                isValid = false;
            }
        });

        if (!isValid) return;

        showLoader("Guardando y enviando a SAP...");

        try {
            const response = await fetch(WEBHOOK_UPDATE_BP, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(dataObject)
            });
            const result = await response.json();
            
            hideLoader();
            
            if (response.ok && result.success) {
            // 1. Mostramos el mensajito flotante por si acaso
            M.toast({html: '✅ ' + result.message, classes: 'green darken-1'});
            
            // 2. Limpiamos la sesión por seguridad
            sessionStorage.clear();
            
            // 3. Reemplazamos el formulario con el mensaje gigante de éxito y una barra de carga
            document.querySelector('.container').innerHTML = `
                <div class="card-panel center-align" style="margin-top: 50px; padding: 40px; border-radius: 10px;">
                    <h4 class="green-text text-darken-2">¡Gracias!</h4>
                    <p style="font-size: 1.2rem;">Sus datos han sido actualizados exitosamente en nuestros sistemas.</p>
                    <p class="grey-text">Lo estamos redirigiendo a la página principal...</p>
                    <div class="progress" style="width: 50%; margin: 20px auto;">
                        <div class="indeterminate"></div>
                    </div>
                </div>
            `;
            
            // 4. Esperamos 4 segundos para que el cliente lea el mensaje y luego redirigimos
            setTimeout(() => {
                window.top.location.href = "https://alorental.cl/clientes1/";
            }, 4000);
            } else {
                M.toast({html: result.message || '❌ Ocurrió un error al actualizar.', classes: 'red darken-1'});
            }
        } catch(e) {
            hideLoader();
            M.toast({html: '❌ Error de conexión al intentar guardar.', classes: 'red darken-1'});
        }
      });

      function showLoader(msg = "Cargando...") {
        document.getElementById('loaderText').innerText = msg;
        document.getElementById('loader').style.display = 'flex';
      }
      function hideLoader() { document.getElementById('loader').style.display = 'none'; }

      function validaRut(rutCompleto) {
        if (!rutCompleto) return false;
        rutCompleto = rutCompleto.replace(/\./g, "").replace("-", "‐");
        if (!/^[0-9]+‐[0-9kK]{1}$/.test(rutCompleto)) return false;
        var tmp = rutCompleto.split('‐');
        var digv = tmp[1]; var rut = tmp[0];
        if (digv == 'K') digv = 'k';
        return (dv(rut) == digv);
      }
      function dv(T) {
        var M = 0, S = 1;
        for (; T; T = Math.floor(T / 10)) { S = (S + T % 10 * (9 - M++ % 6)) % 11; }
        return S ? S - 1 : 'k';
      }
      function isValidEmail(email) { return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email); }
      function isValidPhone(phone) { return /^(\+?56)?(9\d{8}|[2-8]\d{7})$/.test(phone ? phone.trim() : ''); }
    </script>
  </body>
</html>
